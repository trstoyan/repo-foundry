{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-foundry.dev/schemas/review-result.schema.json",
  "title": "Review Result",
  "description": "Structured output from one stateless governance reviewer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "slice_id",
    "reviewer",
    "reviewed_at",
    "status",
    "findings",
    "final_recommendation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "review-result.v1"
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "conditional"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "category",
          "evidence"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "major",
              "minor",
              "note"
            ]
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string"
          }
        }
      }
    },
    "required_followups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reason"
        ],
        "properties": {
          "slice_id": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "final_recommendation": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "conditional"
      ]
    }
  }
}
